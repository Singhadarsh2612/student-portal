<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Profile - Student Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <%- include('partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <%- include('partials/sidebar') %>

      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">
            <i class="bi bi-person"></i> Student Profile
          </h1>
        </div>

        <div class="row">
          <!-- Profile Information Card -->
          <div class="col-md-4 mb-4">
            <div class="card shadow">
              <div class="card-body text-center">
                <div class="profile-avatar mb-3">
                  <%= student.name.charAt(0).toUpperCase() %>
                </div>
                <h4 class="card-title mb-1"><%= student.name %></h4>
                <p class="text-muted mb-3"><%= student.email %></p>
                
                <div class="d-grid gap-2">
                  <button class="btn btn-outline-primary" disabled>
                    <i class="bi bi-pencil"></i> Edit Profile (Coming Soon)
                  </button>
                </div>
              </div>
            </div>

            <!-- Academic Summary Card -->
            <div class="card shadow mt-4">
              <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="bi bi-bar-chart"></i> Academic Summary</h6>
              </div>
              <div class="card-body">
                <div class="mb-3">
                  <div class="d-flex justify-content-between mb-2">
                    <span>Overall Average</span>
                    <strong class="text-primary"><%= overallAverage %>%</strong>
                  </div>
                  <div class="progress">
                    <div class="progress-bar bg-primary" role="progressbar" 
                         style="width: <%= overallAverage %>%" 
                         aria-valuenow="<%= overallAverage %>" 
                         aria-valuemin="0" 
                         aria-valuemax="100"></div>
                  </div>
                </div>

                <div class="mb-3">
                  <div class="d-flex justify-content-between mb-2">
                    <span>Overall Attendance</span>
                    <strong class="text-success"><%= averageAttendance %>%</strong>
                  </div>
                  <div class="progress">
                    <div class="progress-bar bg-success" role="progressbar" 
                         style="width: <%= averageAttendance %>%" 
                         aria-valuenow="<%= averageAttendance %>" 
                         aria-valuemin="0" 
                         aria-valuemax="100"></div>
                  </div>
                </div>

                <hr>

                <div class="row text-center">
                  <div class="col-6 mb-2">
                    <div class="p-2 bg-light rounded">
                      <h4 class="mb-0 text-primary"><%= student.assignedSubjects.length %></h4>
                      <small class="text-muted">Subjects</small>
                    </div>
                  </div>
                  <div class="col-6 mb-2">
                    <div class="p-2 bg-light rounded">
                      <% 
                        let performanceStatus = 'Average';
                        let statusColor = 'warning';
                        if (overallAverage >= 80) {
                          performanceStatus = 'Excellent';
                          statusColor = 'success';
                        } else if (overallAverage < 60) {
                          performanceStatus = 'Needs Work';
                          statusColor = 'danger';
                        }
                      %>
                      <span class="badge bg-<%= statusColor %>"><%= performanceStatus %></span>
                      <br><small class="text-muted">Status</small>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Enrolled Subjects -->
          <div class="col-md-8 mb-4">
            <div class="card shadow">
              <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-book"></i> Enrolled Subjects</h5>
              </div>
              <div class="card-body">
                <div class="table-responsive">
                  <table class="table table-hover">
                    <thead class="table-light">
                      <tr>
                        <th>Subject Name</th>
                        <th>Code</th>
                        <th>Professor</th>
                        <th>Email</th>
                        <th>Attendance</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% student.assignedSubjects.forEach(subject => { %>
                        <tr>
                          <td><strong><%= subject.subjectName %></strong></td>
                          <td><span class="badge bg-secondary"><%= subject.subjectCode %></span></td>
                          <td><%= subject.professorName %></td>
                          <td>
                            <a href="/cdn-cgi/l/email-protection#04382139247771666e6167702a74766b626177776b764169656d6824213a" class="text-decoration-none">
                              <i class="bi bi-envelope"></i> <%= subject.professorEmail %>
                            </a>
                          </td>
                          <td>
                            <span class="badge <%= subject.attendancePercentage >= 75 ? 'bg-success' : 'bg-danger' %>">
                              <%= subject.attendancePercentage %>%
                            </span>
                          </td>
                        </tr>
                      <% }); %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>

            <!-- Performance Insights -->
            <div class="card shadow mt-4">
              <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-lightbulb"></i> Performance Insights</h5>
              </div>
              <div class="card-body">
                <% if (overallAverage >= 80 && averageAttendance >= 90) { %>
                  <div class="alert alert-success">
                    <i class="bi bi-trophy-fill"></i>
                    <strong>Excellent Performance!</strong> You're doing great. Keep up the outstanding work!
                  </div>
                <% } else if (overallAverage < 60) { %>
                  <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>Academic Support Recommended:</strong> Consider reaching out to professors or utilizing tutoring services.
                  </div>
                <% } else { %>
                  <div class="alert alert-info">
                    <i class="bi bi-info-circle-fill"></i>
                    <strong>Good Progress:</strong> You're on track. Focus on consistent improvement.
                  </div>
                <% } %>

                <% if (averageAttendance < 75) { %>
                  <div class="alert alert-danger">
                    <i class="bi bi-calendar-x-fill"></i>
                    <strong>Attendance Alert:</strong> Your attendance is below the minimum requirement. Immediate action needed!
                  </div>
                <% } %>

                <h6 class="mt-4 mb-3">Recommendations:</h6>
                <ul class="list-group">
                  <% if (overallAverage < 70) { %>
                    <li class="list-group-item">
                      <i class="bi bi-book text-primary"></i>
                      Schedule regular study sessions to improve academic performance
                    </li>
                  <% } %>
                  <% if (averageAttendance < 85) { %>
                    <li class="list-group-item">
                      <i class="bi bi-calendar-check text-success"></i>
                      Improve class attendance for better understanding and grades
                    </li>
                  <% } %>
                  <li class="list-group-item">
                    <i class="bi bi-people text-info"></i>
                    Form study groups with classmates for collaborative learning
                  </li>
                  <li class="list-group-item">
                    <i class="bi bi-envelope text-warning"></i>
                    Maintain regular communication with professors for guidance
                  </li>
                </ul>
              </div>
            </div>

            <!-- API Information (for AI Agent) -->
            <div class="card shadow mt-4">
              <div class="card-header bg-dark text-white">
                <h5 class="mb-0"><i class="bi bi-code-slash"></i> API Access</h5>
              </div>
              <div class="card-body">
                <p class="text-muted">Your academic data is accessible via REST API for AI agent integration:</p>
                <div class="bg-light p-3 rounded">
                  <code>
                    Student ID: <%= student._id %><br>
                    API Base: /api/student/<%= student._id %><br><br>
                    Available Endpoints:<br>
                    - /api/student/<%= student._id %><br>
                    - /api/student/<%= student._id %>/subjects<br>
                    - /api/student/<%= student._id %>/marks<br>
                    - /api/student/<%= student._id %>/attendance<br>
                    - /api/student/<%= student._id %>/performance-summary<br>
                    - /api/student/<%= student._id %>/exam-schedule<br>
                    - /api/student/<%= student._id %>/assignments
                  </code>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></sc