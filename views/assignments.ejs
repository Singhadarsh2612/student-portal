<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Assignments - Student Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <%- include('partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <%- include('partials/sidebar') %>

      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">
            <i class="bi bi-file-earmark-text"></i> Assignments
          </h1>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
          <div class="col-md-4 mb-3">
            <div class="card bg-info text-white shadow">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="card-subtitle mb-2">Upcoming</h6>
                    <h2 class="card-title mb-0"><%= upcomingAssignments.length %></h2>
                  </div>
                  <i class="bi bi-clock-history display-4"></i>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card bg-danger text-white shadow">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="card-subtitle mb-2">Overdue</h6>
                    <h2 class="card-title mb-0"><%= overdueAssignments.length %></h2>
                  </div>
                  <i class="bi bi-exclamation-triangle display-4"></i>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-4 mb-3">
            <div class="card bg-success text-white shadow">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="card-subtitle mb-2">Completed</h6>
                    <h2 class="card-title mb-0"><%= completedAssignments.length %></h2>
                  </div>
                  <i class="bi bi-check-circle display-4"></i>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Overdue Assignments Alert -->
        <% if (overdueAssignments.length > 0) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Urgent!</strong> You have <%= overdueAssignments.length %> overdue assignment(s). Please submit them as soon as possible!
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <!-- Upcoming Assignments -->
        <div class="card shadow mb-4">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-check"></i> Upcoming Assignments</h5>
          </div>
          <div class="card-body">
            <% if (upcomingAssignments.length > 0) { %>
              <div class="row">
                <% upcomingAssignments.forEach(assignment => { 
                  const daysLeft = assignment.daysUntilDue();
                  let urgencyClass = 'border-info';
                  let urgencyBadge = 'bg-info';
                  if (daysLeft <= 2) {
                    urgencyClass = 'border-danger';
                    urgencyBadge = 'bg-danger';
                  } else if (daysLeft <= 5) {
                    urgencyClass = 'border-warning';
                    urgencyBadge = 'bg-warning';
                  }
                %>
                  <div class="col-md-6 mb-3">
                    <div class="card h-100 <%= urgencyClass %>" style="border-left: 4px solid;">
                      <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                          <h6 class="card-title mb-0"><%= assignment.title %></h6>
                          <span class="badge <%= urgencyBadge %>"><%= daysLeft %> days left</span>
                        </div>
                        <p class="text-muted small mb-2">
                          <i class="bi bi-book"></i> <%= assignment.subjectId.subjectName %> (<%= assignment.subjectId.subjectCode %>)
                        </p>
                        <p class="card-text"><%= assignment.description %></p>
                        <div class="d-flex justify-content-between align-items-center">
                          <small class="text-muted">
                            <i class="bi bi-calendar"></i> Due: <%= new Date(assignment.dueDate).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %> at <%= new Date(assignment.dueDate).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) %>
                          </small>
                          <span class="badge bg-secondary"><%= assignment.totalMarks %> marks</span>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="text-center py-5">
                <i class="bi bi-check-circle text-success display-1"></i>
                <h4 class="mt-3">All Caught Up!</h4>
                <p class="text-muted">You have no upcoming assignments at the moment.</p>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Overdue Assignments -->
        <% if (overdueAssignments.length > 0) { %>
          <div class="card shadow mb-4 border-danger">
            <div class="card-header bg-danger text-white">
              <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Overdue Assignments</h5>
            </div>
            <div class="card-body">
              <div class="list-group">
                <% overdueAssignments.forEach(assignment => { %>
                  <div class="list-group-item list-group-item-danger">
                    <div class="d-flex w-100 justify-content-between">
                      <h6 class="mb-1"><%= assignment.title %></h6>
                      <small class="text-danger">
                        <i class="bi bi-clock-fill"></i> <%= Math.abs(assignment.daysUntilDue()) %> days overdue
                      </small>
                    </div>
                    <p class="mb-1"><%= assignment.description %></p>
                    <small>
                      <i class="bi bi-book"></i> <%= assignment.subjectId.subjectName %> |
                      <i class="bi bi-calendar-x"></i> Was due: <%= new Date(assignment.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %> at <%= new Date(assignment.dueDate).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true }) %>
                    </small>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        <% } %>

        <!-- Completed Assignments -->
        <div class="card shadow mb-4">
          <div class="card-header bg-success text-white">
            <h5 class="mb-0"><i class="bi bi-check-circle"></i> Completed Assignments</h5>
          </div>
          <div class="card-body">
            <% if (completedAssignments.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead class="table-light">
                    <tr>
                      <th>Assignment</th>
                      <th>Subject</th>
                      <th>Due date</th>
                      <th>Total Marks</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% completedAssignments.forEach(assignment => { %>
                      <tr>
                        <td><strong><%= assignment.title %></strong></td>
                        <td><%= assignment.subjectId.subjectName %></td>
                        <td><%= new Date(assignment.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></td>
                        <td><%= assignment.totalMarks %></td>
                        <td><span class="badge bg-success">Submitted</span></td>
                      </tr>
                    <% }); %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <p class="text-muted text-center py-3">No completed assignments yet.</p>
            <% } %>
          </div>
        </div>

        <!-- Assignment Tips -->
        <div class="card shadow">
          <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="bi bi-lightbulb"></i> Assignment Tips</h5>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-3 mb-3">
                <div class="text-center">
                  <i class="bi bi-calendar-check text-primary display-6"></i>
                  <h6 class="mt-2">Plan Ahead</h6>
                  <p class="text-muted small">Start assignments early to avoid last-minute rush</p>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <div class="text-center">
                  <i class="bi bi-search text-success display-6"></i>
                  <h6 class="mt-2">Research Well</h6>
                  <p class="text-muted small">Use credible sources and cite properly</p>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <div class="text-center">
                  <i class="bi bi-pencil-square text-warning display-6"></i>
                  <h6 class="mt-2">Proofread</h6>
                  <p class="text-muted small">Always review your work before submission</p>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <div class="text-center">
                  <i class="bi bi-person-check text-info display-6"></i>
                  <h6 class="mt-2">Ask for Help</h6>
                  <p class="text-muted small">Reach out to professors if you're stuck</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
