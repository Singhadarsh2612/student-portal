<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Attendance - Student Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <%- include('partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <%- include('partials/sidebar') %>

      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">
            <i class="bi bi-calendar-check"></i> Attendance Records
          </h1>
        </div>

        <!-- Attendance Cards -->
        <div class="row mb-4">
          <% subjects.forEach(subject => { %>
            <div class="col-md-6 col-lg-4 mb-4">
              <div class="card shadow h-100 <%= subject.attendancePercentage < 75 ? 'border-danger' : '' %>">
                <div class="card-header <%= subject.attendancePercentage >= 75 ? 'bg-success' : 'bg-danger' %> text-white">
                  <h5 class="mb-0"><%= subject.subjectName %></h5>
                  <small><%= subject.subjectCode %></small>
                </div>
                <div class="card-body">
                  <!-- Attendance Progress -->
                  <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                      <span>Attendance</span>
                      <strong><%= subject.attendancePercentage %>%</strong>
                    </div>
                    <div class="progress" style="height: 20px;">
                      <div class="progress-bar <%= subject.attendancePercentage >= 75 ? 'bg-success' : 'bg-danger' %>" 
                           role="progressbar" 
                           style="width: <%= subject.attendancePercentage %>%"
                           aria-valuenow="<%= subject.attendancePercentage %>" 
                           aria-valuemin="0" 
                           aria-valuemax="100">
                        <%= subject.attendancePercentage %>%
                      </div>
                    </div>
                  </div>

                  <!-- Attendance Stats -->
                  <div class="row text-center mb-3">
                    <div class="col-6">
                      <div class="p-2 bg-light rounded">
                        <h4 class="text-success mb-0"><%= subject.classesAttended %></h4>
                        <small class="text-muted">Present</small>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="p-2 bg-light rounded">
                        <h4 class="text-primary mb-0"><%= subject.totalClasses %></h4>
                        <small class="text-muted">Total</small>
                      </div>
                    </div>
                  </div>

                  <!-- Warning -->
                  <% if (subject.attendancePercentage < 75) { %>
                    <div class="alert alert-warning mb-3">
                      <i class="bi bi-exclamation-triangle-fill"></i>
                      <small><strong>Warning:</strong> Below 75% threshold!</small>
                    </div>
                  <% } %>

                  <!-- Professor Info -->
                  <div class="border-top pt-3">
                    <p class="mb-1">
                      <i class="bi bi-person"></i> 
                      <strong>Professor:</strong> <%= subject.professorName %>
                    </p>
                    <p class="mb-0">
                      <i class="bi bi-envelope"></i>
                      <a href="/cdn-cgi/l/email-protection#19253c24396a6c7b737c7a6d37696b767f7c6a6a766b5c74787075393c27"><%= subject.professorEmail %></a>
                    </p>
                  </div>

                  <!-- Classes to Attend Calculation -->
                  <% 
                    const missedClasses = subject.totalClasses - subject.classesAttended;
                    let classesToAttend = 0;
                    if (subject.attendancePercentage < 75) {
                      // Calculate classes needed to reach 75%
                      classesToAttend = Math.ceil((0.75 * subject.totalClasses - subject.classesAttended) / 0.25);
                    }
                  %>
                  <% if (classesToAttend > 0) { %>
                    <div class="alert alert-info mt-3">
                      <small>
                        <i class="bi bi-info-circle"></i>
                        Attend next <strong><%= classesToAttend %></strong> classes continuously to reach 75%
                      </small>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>

        <!-- Attendance Summary Table -->
        <div class="card shadow">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-table"></i> Attendance Summary</h5>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover">
                <thead class="table-dark">
                  <tr>
                    <th>Subject</th>
                    <th>Code</th>
                    <th>Professor</th>
                    <th>Present</th>
                    <th>Total Classes</th>
                    <th>Percentage</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% subjects.forEach(subject => { %>
                    <tr>
                      <td><strong><%= subject.subjectName %></strong></td>
                      <td><span class="badge bg-secondary"><%= subject.subjectCode %></span></td>
                      <td><%= subject.professorName %></td>
                      <td><%= subject.classesAttended %></td>
                      <td><%= subject.totalClasses %></td>
                      <td>
                        <span class="badge <%= subject.attendancePercentage >= 75 ? 'bg-success' : 'bg-danger' %>">
                          <%= subject.attendancePercentage %>%
                        </span>
                      </td>
                      <td>
                        <% if (subject.attendancePercentage >= 75) { %>
                          <span class="badge bg-success">
                            <i class="bi bi-check-circle"></i> Good
                          </span>
                        <% } else { %>
                          <span class="badge bg-danger">
                            <i class="bi bi-exclamation-triangle"></i> Low
                          </span>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></sc