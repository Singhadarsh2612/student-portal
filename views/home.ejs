<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Portal - Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="home-container">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
      <div class="container">
        <a class="navbar-brand" href="/">
          <i class="bi bi-mortarboard-fill"></i> Academic Portal
        </a>
      </div>
    </nav>

    <div class="hero-section">
      <div class="container text-center">
        <h1 class="display-3 mb-4">Welcome to Academic Portal</h1>
        <p class="lead mb-5">Your one-stop solution for managing academic performance, attendance, and more</p>
        
        <div class="row justify-content-center mt-5">
          <div class="col-md-5 mb-4">
            <div class="card shadow-lg">
              <div class="card-body p-5">
                <i class="bi bi-box-arrow-in-right display-4 text-primary mb-3"></i>
                <h3 class="card-title mb-3">Login</h3>
                <p class="card-text text-muted mb-4">Already have an account? Sign in to access your dashboard</p>
                <a href="/login" class="btn btn-primary btn-lg w-100">
                  <i class="bi bi-arrow-right-circle"></i> Login
                </a>
              </div>
            </div>
          </div>
          
          <div class="col-md-5 mb-4">
            <div class="card shadow-lg">
              <div class="card-body p-5">
                <i class="bi bi-person-plus-fill display-4 text-success mb-3"></i>
                <h3 class="card-title mb-3">Register</h3>
                <p class="card-text text-muted mb-4">New student? Create your account to get started</p>
                <a href="/register" class="btn btn-success btn-lg w-100">
                  <i class="bi bi-arrow-right-circle"></i> Register
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="row mt-5 text-start">
          <div class="col-md-4 mb-4">
            <div class="feature-box">
              <i class="bi bi-graph-up-arrow text-primary display-5 mb-3"></i>
              <h5>Track Performance</h5>
              <p class="text-muted">Monitor your academic progress with detailed marks and analytics</p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="feature-box">
              <i class="bi bi-calendar-check text-success display-5 mb-3"></i>
              <h5>Attendance Management</h5>
              <p class="text-muted">Keep track of your attendance across all subjects</p>
            </div>
          </div>
          <div class="col-md-4 mb-4">
            <div class="feature-box">
              <i class="bi bi-book text-info display-5 mb-3"></i>
              <h5>Subject Information</h5>
              <p class="text-muted">Access subject details and professor contact information</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <footer class="footer mt-5 py-3 bg-light">
      <div class="container text-center">
        <span class="text-muted">© 2024 Academic Student Portal. All rights reserved.</span>
      </div>
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
