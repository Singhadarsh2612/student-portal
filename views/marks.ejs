<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marks - Student Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <%- include('partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <%- include('partials/sidebar') %>

      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">
            <i class="bi bi-clipboard-data"></i> Examination Marks
          </h1>
        </div>

        <!-- Subject-wise Marks Cards -->
        <div class="row mb-4">
          <% marks.forEach(mark => { %>
            <div class="col-md-12 mb-4">
              <div class="card shadow">
                <div class="card-header bg-primary text-white">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h5 class="mb-0"><%= mark.subjectId.subjectName %></h5>
                      <small><%= mark.subjectId.subjectCode %></small>
                    </div>
                    <div class="text-end">
                      <h4 class="mb-0">Average: <%= mark.calculateAverage() %>%</h4>
                      <small>Overall Performance</small>
                    </div>
                  </div>
                </div>
                <div class="card-body">
                  <div class="row text-center">
                    <!-- Quizzes -->
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-light rounded">
                        <i class="bi bi-pencil-square text-info"></i>
                        <h5 class="mt-2 mb-0"><%= mark.quiz1 %></h5>
                        <small class="text-muted">Quiz 1</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-light rounded">
                        <i class="bi bi-pencil-square text-info"></i>
                        <h5 class="mt-2 mb-0"><%= mark.quiz2 %></h5>
                        <small class="text-muted">Quiz 2</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-light rounded">
                        <i class="bi bi-pencil-square text-info"></i>
                        <h5 class="mt-2 mb-0"><%= mark.quiz3 %></h5>
                        <small class="text-muted">Quiz 3</small>
                      </div>
                    </div>
                    
                    <!-- Mid Semester -->
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-warning rounded">
                        <i class="bi bi-file-earmark-text text-white"></i>
                        <h5 class="mt-2 mb-0 text-white"><%= mark.midSem %></h5>
                        <small class="text-white"><strong>Mid Sem</strong></small>
                      </div>
                    </div>

                    <!-- More Quizzes -->
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-light rounded">
                        <i class="bi bi-pencil-square text-info"></i>
                        <h5 class="mt-2 mb-0"><%= mark.quiz4 %></h5>
                        <small class="text-muted">Quiz 4</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-light rounded">
                        <i class="bi bi-pencil-square text-info"></i>
                        <h5 class="mt-2 mb-0"><%= mark.quiz5 %></h5>
                        <small class="text-muted">Quiz 5</small>
                      </div>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-light rounded">
                        <i class="bi bi-pencil-square text-info"></i>
                        <h5 class="mt-2 mb-0"><%= mark.quiz6 %></h5>
                        <small class="text-muted">Quiz 6</small>
                      </div>
                    </div>

                    <!-- End Semester -->
                    <div class="col-6 col-md-3 mb-3">
                      <div class="p-3 bg-danger rounded">
                        <i class="bi bi-file-earmark-text text-white"></i>
                        <h5 class="mt-2 mb-0 text-white"><%= mark.endSem %></h5>
                        <small class="text-white"><strong>End Sem</strong></small>
                      </div>
                    </div>
                  </div>

                  <!-- Performance Bar -->
                  <div class="mt-3">
                    <div class="d-flex justify-content-between mb-1">
                      <span>Subject Performance</span>
                      <strong><%= mark.calculateAverage() %>%</strong>
                    </div>
                    <div class="progress" style="height: 25px;">
                      <% 
                        const avg = mark.calculateAverage();
                        let progressColor = 'bg-danger';
                        if (avg >= 80) progressColor = 'bg-success';
                        else if (avg >= 60) progressColor = 'bg-warning';
                      %>
                      <div class="progress-bar <%= progressColor %>" 
                           role="progressbar" 
                           style="width: <%= avg %>%"
                           aria-valuenow="<%= avg %>" 
                           aria-valuemin="0" 
                           aria-valuemax="100">
                        <%= avg %>%
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>

        <!-- Marks Summary Table -->
        <div class="card shadow">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-table"></i> Detailed Marks Summary</h5>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover table-striped">
                <thead class="table-dark">
                  <tr>
                    <th>Subject</th>
                    <th>Code</th>
                    <th>Q1</th>
                    <th>Q2</th>
                    <th>Q3</th>
                    <th>Mid Sem</th>
                    <th>Q4</th>
                    <th>Q5</th>
                    <th>Q6</th>
                    <th>End Sem</th>
                    <th>Average</th>
                    <th>Grade</th>
                  </tr>
                </thead>
                <tbody>
                  <% marks.forEach(mark => { 
                    const avg = mark.calculateAverage();
                    let grade = 'F';
                    if (avg >= 90) grade = 'A+';
                    else if (avg >= 80) grade = 'A';
                    else if (avg >= 70) grade = 'B';
                    else if (avg >= 60) grade = 'C';
                    else if (avg >= 50) grade = 'D';
                  %>
                    <tr>
                      <td><strong><%= mark.subjectId.subjectName %></strong></td>
                      <td><span class="badge bg-secondary"><%= mark.subjectId.subjectCode %></span></td>
                      <td><%= mark.quiz1 %></td>
                      <td><%= mark.quiz2 %></td>
                      <td><%= mark.quiz3 %></td>
                      <td><strong><%= mark.midSem %></strong></td>
                      <td><%= mark.quiz4 %></td>
                      <td><%= mark.quiz5 %></td>
                      <td><%= mark.quiz6 %></td>
                      <td><strong><%= mark.endSem %></strong></td>
                      <td>
                        <span class="badge <%= avg >= 60 ? 'bg-success' : 'bg-danger' %>">
                          <%= avg %>%
                        </span>
                      </td>
                      <td>
                        <span class="badge bg-primary"><%= grade %></span>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
