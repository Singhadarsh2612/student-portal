<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Student Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <%- include('partials/navbar') %>

  <div class="container-fluid">
    <div class="row">
      <!-- Sidebar -->
      <%- include('partials/sidebar') %>

      <!-- Main Content -->
      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">
            <i class="bi bi-speedometer2"></i> Dashboard
          </h1>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
          <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white shadow">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="card-subtitle mb-2">Total Subjects</h6>
                    <h2 class="card-title mb-0"><%= subjects.length %></h2>
                  </div>
                  <i class="bi bi-book display-4"></i>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-3 mb-3">
            <div class="card bg-success text-white shadow">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="card-subtitle mb-2">Average Marks</h6>
                    <h2 class="card-title mb-0"><%= averageMarks %>%</h2>
                  </div>
                  <i class="bi bi-graph-up display-4"></i>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-3 mb-3">
            <div class="card bg-info text-white shadow">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="card-subtitle mb-2">Avg Attendance</h6>
                    <h2 class="card-title mb-0"><%= averageAttendance %>%</h2>
                  </div>
                  <i class="bi bi-calendar-check display-4"></i>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-3 mb-3">
            <div class="card <%= lowAttendanceSubjects.length > 0 ? 'bg-warning' : 'bg-secondary' %> text-white shadow">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <div>
                    <h6 class="card-subtitle mb-2">Low Attendance</h6>
                    <h2 class="card-title mb-0"><%= lowAttendanceSubjects.length %></h2>
                  </div>
                  <i class="bi bi-exclamation-triangle display-4"></i>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Alerts -->
        <% if (lowAttendanceSubjects.length > 0) { %>
          <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <strong>Attention Required!</strong> You have low attendance in <%= lowAttendanceSubjects.length %> subject(s). 
            Please improve your attendance to meet the minimum requirement.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <!-- Academic Performance Table -->
        <div class="card shadow mb-4">
          <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-table"></i> Academic Performance Overview</h5>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover table-striped">
                <thead class="table-dark">
                  <tr>
                    <th>Subject</th>
                    <th>Code</th>
                    <th>Professor</th>
                    <th>Attendance</th>
                    <th>Quiz 1</th>
                    <th>Quiz 2</th>
                    <th>Quiz 3</th>
                    <th>Mid Sem</th>
                    <th>Quiz 4</th>
                    <th>Quiz 5</th>
                    <th>Quiz 6</th>
                    <th>End Sem</th>
                    <th>Average</th>
                  </tr>
                </thead>
                <tbody>
                  <% subjects.forEach(subject => { 
                    const marks = marksMap[subject._id.toString()];
                  %>
                    <tr>
                      <td><strong><%= subject.subjectName %></strong></td>
                      <td><span class="badge bg-secondary"><%= subject.subjectCode %></span></td>
                      <td><%= subject.professorName %></td>
                      <td>
                        <span class="badge <%= subject.attendancePercentage >= 75 ? 'bg-success' : 'bg-danger' %>">
                          <%= subject.attendancePercentage %>%
                        </span>
                      </td>
                      <% if (marks) { %>
                        <td><%= marks.quiz1 %></td>
                        <td><%= marks.quiz2 %></td>
                        <td><%= marks.quiz3 %></td>
                        <td><strong><%= marks.midSem %></strong></td>
                        <td><%= marks.quiz4 %></td>
                        <td><%= marks.quiz5 %></td>
                        <td><%= marks.quiz6 %></td>
                        <td><strong><%= marks.endSem %></strong></td>
                        <td>
                          <span class="badge <%= marks.calculateAverage() >= 60 ? 'bg-success' : 'bg-warning' %>">
                            <%= marks.calculateAverage() %>%
                          </span>
                        </td>
                      <% } else { %>
                        <td colspan="9" class="text-center text-muted">No marks data available</td>
                      <% } %>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Placeholder Sections for Future AI Integration -->
        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="card shadow">
              <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-lightbulb"></i> AI Study Recommendations</h5>
              </div>
              <div class="card-body">
                <p class="text-muted">
                  <i class="bi bi-robot"></i> AI-powered study recommendations will appear here based on your performance.
                </p>
                <div class="alert alert-light">
                  <small><em>Feature coming soon with AI integration...</em></small>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="card shadow">
              <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-calendar-event"></i> Upcoming Exams</h5>
              </div>
              <div class="card-body">
                <p class="text-muted">
                  <i class="bi bi-clock"></i> Upcoming exam schedule will be displayed here.
                </p>
                <div class="alert alert-light">
                  <small><em>Feature coming soon...</em></small>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="card shadow">
              <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-list-check"></i> Assignment Deadlines</h5>
              </div>
              <div class="card-body">
                <p class="text-muted">
                  <i class="bi bi-pencil-square"></i> Upcoming assignment deadlines will be shown here.
                </p>
                <div class="alert alert-light">
                  <small><em>Feature coming soon...</em></small>
                </div>
              </div>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="card shadow">
              <div class="card-header bg-success text-white">
                <h5 class="mb-0"><i class="bi bi-bell"></i> Notifications</h5>
              </div>
              <div class="card-body">
                <p class="text-muted">
                  <i class="bi bi-envelope"></i> Important notifications and announcements will appear here.
                </p>
                <div class="alert alert-light">
                  <small><em>Feature coming soon...</em></small>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
